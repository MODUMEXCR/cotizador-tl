@page "/mis-proyectos"
@inject AuthService Auth
@inject CatalogoService Catalogo
@inject Supabase.Client Supa
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Mis Proyectos</PageTitle>

<h1>Mis Proyectos</h1>
<p class="lead">
    @(Auth.PuedeVerTodo ? "Todas las cotizaciones." : "Tus cotizaciones.") Filtra por fecha@(Auth.PuedeVerTodo ? " o distribuidor" : "") y descarga el PDF o el Excel.
</p>

@if (cargando)
{
    <p>Cargando…</p>
}
else
{
    <section class="card">
        <div class="filtros">
            <label>Desde<input type="date" @bind="desde" /></label>
            <label>Hasta<input type="date" @bind="hasta" /></label>
            @if (Auth.PuedeVerTodo)
            {
                <label>Distribuidor
                    <select @bind="filtroDistribuidor">
                        <option value="0">Todos</option>
                        @foreach (var d in Catalogo.Distribuidores)
                        {
                            <option value="@d.DistribuidorId">@d.Nombre</option>
                        }
                    </select>
                </label>
            }
            <label>Estado
                <select @bind="filtroEstado">
                    <option value="">Todos</option>
                    <option value="borrador">Borrador</option>
                    <option value="enviada">Enviada</option>
                    <option value="aceptada">Aprobada</option>
                    <option value="rechazada">Rechazada</option>
                </select>
            </label>
            <button class="btn-add" @onclick="LimpiarFiltros">Limpiar</button>
            @if (Auth.EsAdmin)
            {
                <button class="btn-add" style="background:var(--tl-verde-h)" @onclick="DescargarLista">Descargar lista (Excel)</button>
            }
        </div>

        <div class="tabla-wrap">
            <table class="proyectos">
                <thead>
                    <tr>
                        <th>Expediente</th><th>Fecha</th>
                        @if (Auth.PuedeVerTodo) { <th>Distribuidor</th> }
                        <th>Cliente</th><th>Proyecto</th><th class="num">Gran total</th>
                        <th>Estado</th><th>Fabricación</th><th>Descargas</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Filtradas)
                    {
                        <tr @ondblclick="() => Abrir(c)" title="Doble clic para abrir/editar" style="cursor:pointer">
                            <td><b>@c.Folio</b></td>
                            <td>@c.Fecha.ToLocalTime().ToString("dd/MM/yyyy")</td>
                            @if (Auth.PuedeVerTodo) { <td>@NombreDist(c.DistribuidorId)</td> }
                            <td>@c.Cliente</td>
                            <td>@c.Proyecto</td>
                            <td class="num">@((c.Moneda == "CRC" ? "₡" : "$") + c.GranTotal.ToString("#,##0.00"))</td>
                            <td @onclick:stopPropagation="true" @ondblclick:stopPropagation="true">
                                @if (Auth.EsAdmin)
                                {
                                    <select value="@(string.IsNullOrEmpty(c.Estado) ? "borrador" : c.Estado)" @onchange="e => GuardarEstado(c, e.Value?.ToString())">
                                        <option value="borrador">Borrador</option>
                                        <option value="enviada">Enviada</option>
                                        <option value="aceptada">Aprobada</option>
                                        <option value="rechazada">Rechazada</option>
                                    </select>
                                }
                                else
                                {
                                    <span class="estado">@EstadoLabel(c.Estado)</span>
                                }
                            </td>
                            <td @onclick:stopPropagation="true" @ondblclick:stopPropagation="true">
                                @if (Auth.PuedeVerTodo)
                                {
                                    <select value="@(c.Fabricacion ?? "")" @onchange="e => GuardarFabricacion(c, e.Value?.ToString())">
                                        <option value="">— Sin asignar —</option>
                                        <option value="México">México</option>
                                        <option value="Costa Rica">Costa Rica</option>
                                    </select>
                                }
                                else
                                {
                                    @(string.IsNullOrEmpty(c.Fabricacion) ? "—" : c.Fabricacion)
                                }
                            </td>
                            <td class="acciones">
                                <button class="btn-mini xls" @onclick="() => Abrir(c)" style="background:var(--tl-verde-h)">Abrir</button>
                                <button class="btn-mini pdf" @onclick="() => DescargarPdf(c)" style="background:#c0392b">PDF</button>
                                <button class="btn-mini xls" @onclick="() => DescargarExcel(c)">Excel</button>
                                @if (Auth.PuedeVerTodo)
                                { <button class="btn-mini pdf" @onclick="() => Eliminar(c)">Eliminar</button> }
                            </td>
                        </tr>
                    }
                    @if (!Filtradas.Any())
                    {
                        <tr><td colspan="@(Auth.PuedeVerTodo ? 9 : 8)" class="muted center">No hay cotizaciones con esos filtros.</td></tr>
                    }
                </tbody>
            </table>
        </div>
        @if (mensaje is not null) { <div class="aviso err">@mensaje</div> }
    </section>
}

@code {
    private bool cargando = true;
    private List<PCotizacion> todas = new();
    private DateTime? desde, hasta;
    private long filtroDistribuidor;
    private string filtroEstado = "";
    private string? mensaje;

    private static string EstadoLabel(string? code) => (code ?? "borrador") switch
    {
        "enviada" => "Enviada",
        "aceptada" => "Aprobada",
        "rechazada" => "Rechazada",
        _ => "Borrador",
    };

    protected override async Task OnInitializedAsync()
    {
        await Catalogo.CargarAsync();
        // RLS limita automáticamente: el distribuidor solo ve las suyas.
        var resp = await Supa.From<PCotizacion>()
                             .Order("fecha", Supabase.Postgrest.Constants.Ordering.Descending).Get();
        todas = resp.Models;
        cargando = false;
    }

    private IEnumerable<PCotizacion> Filtradas => todas.Where(c =>
        (desde is null || c.Fecha.ToLocalTime().Date >= desde.Value.Date) &&
        (hasta is null || c.Fecha.ToLocalTime().Date <= hasta.Value.Date) &&
        (filtroDistribuidor == 0 || c.DistribuidorId == filtroDistribuidor) &&
        (filtroEstado == "" || (string.IsNullOrEmpty(c.Estado) ? "borrador" : c.Estado) == filtroEstado));

    private void LimpiarFiltros() { desde = hasta = null; filtroDistribuidor = 0; filtroEstado = ""; }

    private void Abrir(PCotizacion c) => Nav.NavigateTo($"cotizar/{c.CotizacionId}");

    private async Task GuardarFabricacion(PCotizacion c, string? valor)
    {
        mensaje = null;
        try
        {
            c.Fabricacion = string.IsNullOrEmpty(valor) ? null : valor;
            if (c.Fecha.Year < 2000) c.Fecha = DateTime.UtcNow;   // repara expedientes viejos sin fecha
            await Supa.From<PCotizacion>().Update(c);
            StateHasChanged();
        }
        catch (Exception ex) { mensaje = "No se pudo guardar el lugar de fabricación: " + ex.Message; }
    }

    private async Task GuardarEstado(PCotizacion c, string? code)
    {
        mensaje = null;
        if (!Auth.EsAdmin) return;   // solo Administradores cambian el estado
        try
        {
            c.Estado = string.IsNullOrEmpty(code) ? "borrador" : code;
            if (c.Fecha.Year < 2000) c.Fecha = DateTime.UtcNow;
            await Supa.From<PCotizacion>().Update(c);
            StateHasChanged();
        }
        catch (Exception ex) { mensaje = "No se pudo guardar el estado: " + ex.Message; }
    }

    private async Task DescargarLista()
    {
        mensaje = null;
        if (!Auth.EsAdmin) return;   // solo Administradores exportan la lista
        try
        {
            var filas = Filtradas.Select(c => new
            {
                folio = c.Folio,
                fecha = c.Fecha.ToLocalTime().ToString("dd/MM/yyyy"),
                distribuidor = NombreDist(c.DistribuidorId),
                cliente = c.Cliente, proyecto = c.Proyecto,
                granTotal = (double)c.GranTotal,
                estado = EstadoLabel(c.Estado),
                fabricacion = c.Fabricacion ?? "",
                moneda = c.Moneda,
            }).ToArray();
            if (filas.Length == 0) { mensaje = "No hay cotizaciones que exportar con esos filtros."; return; }
            await JS.InvokeVoidAsync("cotizadorExcel.generarLista", (object)filas);
        }
        catch (Exception ex) { mensaje = "No se pudo generar el Excel de la lista: " + ex.Message; }
    }

    private async Task Eliminar(PCotizacion c)
    {
        mensaje = null;
        if (!await JS.InvokeAsync<bool>("confirm", $"¿Eliminar la cotización {c.Folio}? Esta acción no se puede deshacer.")) return;
        try
        {
            await Supa.From<PCotizacion>().Where(x => x.CotizacionId == c.CotizacionId).Delete();
            todas.Remove(c);
        }
        catch (Exception ex) { mensaje = "No se pudo eliminar: " + ex.Message; }
    }

    private string NombreDist(long? id) =>
        Catalogo.Distribuidores.FirstOrDefault(d => d.DistribuidorId == id)?.Nombre ?? "—";

    private async Task<List<PCotizacionLinea>> CargarLineas(long cotId) =>
        (await Supa.From<PCotizacionLinea>().Where(l => l.CotizacionId == cotId)
                   .Order("orden", Supabase.Postgrest.Constants.Ordering.Ascending).Get()).Models;

    private async Task DescargarPdf(PCotizacion c)
    {
        try
        {
            var ls = await CargarLineas(c.CotizacionId);
            var dto = new
            {
                folio = c.Folio,
                vigencia = c.Vigencia?.ToString("dd/MM/yyyy") ?? "", entrega = c.Entrega,
                razonSocial = c.RazonSocial, proyecto = c.Proyecto, titulo = c.Titulo,
                cliente = c.Cliente, atencionA = c.AtencionA, telefono = c.Telefono,
                ciudad = c.Ciudad, cotizadoPor = c.CotizadoPor, comentarios = c.Comentarios,
                descuentoPct = c.DescuentoPct.ToString("0.#"), ivaPct = c.IvaPct.ToString("0.#"),
                anticipoPct = (double)c.AnticipoPct, datosBancarios = c.DatosBancarios,
                totales = new
                {
                    subtotal = (double)c.Subtotal, descuentoMonto = (double)c.DescuentoMonto,
                    subtotalDesc = (double)c.SubtotalDesc,
                    gastosIndirectos = (double)c.GastosIndirectos, gastosEnvio = (double)c.GastosEnvio,
                    ivaMonto = (double)c.IvaMonto,
                    granTotal = (double)c.GranTotal, anticipo = (double)c.AnticipoMonto, saldo = (double)c.SaldoMonto,
                },
                lineas = ls.Select(l => new
                {
                    cantidad = (double)l.Cantidad, codigoSap = l.CodigoSap, descripcion = l.Descripcion,
                    color = l.Color, precioUnitario = (double)l.PrecioUnitario, importe = (double)l.Subtotal,
                }).ToArray(),
            };
            await JS.InvokeVoidAsync("cotizadorPdf.generar", dto);
        }
        catch (Exception ex) { mensaje = "No se pudo generar el PDF: " + ex.Message; }
    }

    private async Task DescargarExcel(PCotizacion c)
    {
        try
        {
            var ls = await CargarLineas(c.CotizacionId);
            var rows = ls.Select(l => new
            {
                codigoSap = l.CodigoSap, descripcion = l.Descripcion, textoLibre = l.TextoLibre,
                cantidad = (double)l.Cantidad, precioUnitario = (double)l.PrecioUnitario,
                desc1 = (double)l.DescuentoPct,        // Descuento de renglón (familia)
                desc2 = (double)c.DescuentoPct,        // Descuento adicional (global)
            }).ToArray();
            var info = new
            {
                folio = c.Folio, fecha = c.Fecha.ToLocalTime().ToString("dd/MM/yyyy"),
                cliente = c.Cliente, ciudad = c.Ciudad, atencion = c.AtencionA,
                distribuidor = NombreDist(c.DistribuidorId), proyecto = c.Proyecto,
                fabricacion = c.Fabricacion, moneda = c.Moneda,
            };
            await JS.InvokeVoidAsync("cotizadorExcel.generar", info, rows);
        }
        catch (Exception ex) { mensaje = "No se pudo generar el Excel: " + ex.Message; }
    }
}
