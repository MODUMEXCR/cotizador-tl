@page "/"
@page "/cotizar/{CotId:long}"
@inject AuthService Auth
@inject CatalogoService Catalogo
@inject Supabase.Client Supa
@inject IJSRuntime JS

<PageTitle>Cotizar · Thin Laminates</PageTitle>

<h1>Cotizar</h1>

@if (cargando)
{
    <p>Cargando catálogo…</p>
}
else
{
    <div class="cot-grid">
        <!-- ENCABEZADO -->
        <section class="card">
            <h2>Datos de la cotización</h2>
            <div class="campos">
                <label>Expediente<input value="@(string.IsNullOrEmpty(cot.Folio) ? "(se asigna luego)" : cot.Folio)" disabled /></label>
                <label>Vigencia<input type="date" @bind="vigencia" /></label>
                <label>Tiempo de entrega
                    <select @bind="entrega">
                        @for (int s = 1; s <= 16; s++)
                        {
                            var v = $"{s} semana{(s == 1 ? "" : "s")}";
                            <option value="@v">@v</option>
                        }
                    </select>
                </label>
                <label>Distribuidor
                    @if (Auth.PuedeVerTodo)
                    {
                        <select @bind="distribuidorId" @bind:after="OnDistribuidorChanged">
                            <option value="0">— Selecciona —</option>
                            @foreach (var d in Catalogo.Distribuidores)
                            { <option value="@d.DistribuidorId">@d.Nombre (@d.DescuentoPct.ToString("0.#")%)</option> }
                        </select>
                    }
                    else { <input value="@nombreDistribuidorActual" disabled /> }
                </label>
                <label>Razón social<input @bind="cot.RazonSocial" /></label>
                <label>Proyecto<input @bind="cot.Proyecto" /></label>
                <label>Título (barra verde)<input @bind="cot.Titulo" placeholder="Ej. CUBIERTA PARA EXTERIOR" /></label>
                <label>Cliente<input @bind="cot.Cliente" /></label>
                <label>Atención a<input @bind="cot.AtencionA" /></label>
                <label>Teléfono<input @bind="cot.Telefono" /></label>
                <label>Ciudad<input @bind="cot.Ciudad" /></label>
                <label>Cotizado por<input value="@cot.CotizadoPor" disabled /></label>
                @if (Auth.PuedeVerTodo)
                {
                    <label>Lugar de fabricación
                        <select @bind="fabricacion" @bind:after="OnFabricacionChanged">
                            <option value="México">México (colores MXN)</option>
                            <option value="Costa Rica">Costa Rica (colores LATAM)</option>
                        </select>
                    </label>
                    <label>Moneda
                        <select @bind="monedaSel" @bind:after="OnMonedaChanged">
                            <option value="MXN">Pesos MXN</option>
                            <option value="USD">Dólares LATAM (USD)</option>
                            <option value="CRC">Colones CRC</option>
                        </select>
                    </label>
                }
            </div>
            <div class="campos">
                <label>Descuento adicional % (admin)<input type="number" step="0.01" @bind="cot.DescuentoPct" disabled="@(!Auth.EsAdmin)" /></label>
                <label>IVA %<input type="number" step="0.01" @bind="cot.IvaPct" disabled="@(!Auth.EsAdmin)" /></label>
                <label>Anticipo %<input type="number" value="60" disabled /></label>
            </div>
            <label>Comentarios o instrucciones especiales<textarea @bind="cot.Comentarios" rows="2"></textarea></label>
        </section>

        <!-- RENGLONES (configurador) -->
        <section class="card">
            <h2>Renglones <button class="btn-add" @onclick="AgregarLinea">+ Agregar renglón</button></h2>

            @foreach (var l in lineas)
            {
                var prod = ProdDe(l);
                <div class="renglon-card">
                    <div class="renglon-top">
                        <label>Familia
                            <select @bind="l.FamiliaCodigo" @bind:after="() => OnFamiliaChanged(l)">
                                <option value="">—</option>
                                @foreach (var f in Catalogo.Familias)
                                { <option value="@f.Codigo">@f.Nombre</option> }
                            </select>
                        </label>
                        <label>Producto
                            <select @bind="l.ProductoIdStr" @bind:after="() => OnProductoChanged(l)">
                                <option value="">—</option>
                                @foreach (var p in ProductosPrincipales(l.FamiliaCodigo))
                                { <option value="@p.ProductoId">@p.CodigoSap · @p.Nombre</option> }
                            </select>
                        </label>
                        <label class="mini">Cant.<input type="number" min="1" step="1" @bind="l.Cantidad" @bind:after="StateHasChanged" /></label>
                        <label class="mini">Desc.%<input type="number" min="0" max="100" step="0.01" @bind="l.DescuentoPct" @bind:after="StateHasChanged"
                                    disabled="@(prod is { AplicaDescuento:false } || !Auth.EsAdmin)" /></label>
                        <button class="btn-del" @onclick="() => QuitarLinea(l)" title="Quitar">✕</button>
                    </div>

                    @if (prod is not null)
                    {
                        <div class="renglon-opts">
                            @* Medidas para productos por m² *@
                            @if (prod.RequiereMedidas && prod.MedidaUnica)
                            {
                                <label class="mini">Medida (cm)<input type="number" step="0.1" max="@MaxMedida(l)" @bind="l.LargoCm" @bind:after="() => OnColorChanged(l)" /></label>
                            }
                            else if (prod.RequiereMedidas)
                            {
                                <label class="mini">Largo (cm)<input type="number" step="0.1" max="@MaxMedida(l)" @bind="l.LargoCm" @bind:after="() => OnColorChanged(l)" /></label>
                                <label class="mini">Ancho (cm)<input type="number" step="0.1" max="@MaxMedida(l)" @bind="l.AnchoCm" @bind:after="() => OnColorChanged(l)" /></label>
                            }
                            @if (l.Aviso is not null)
                            {
                                <span class="small" style="color:var(--tl-verde-txt);align-self:center">@l.Aviso</span>
                            }

                            @* Espesor para lockers especiales por m² *@
                            @if (EsFamilia(l, "LOCKERS") && prod.TipoPrecio == "m2")
                            {
                                <label class="mini">Espesor
                                    <select @bind="l.Grupo" @bind:after="StateHasChanged">
                                        @foreach (var g in prod.Precios.Keys) { <option value="@g">@g</option> }
                                    </select>
                                </label>
                            }

                            @* Cubiertas: interior/exterior + color (define grupo/precio) *@
                            @if (EsFamilia(l, "CUBIERTAS"))
                            {
                                <label class="mini">Tipo
                                    <select @bind="l.TipoStr" @bind:after="() => OnTipoChanged(l)">
                                        <option value="Interior">Interior</option>
                                        <option value="Exterior">Exterior</option>
                                    </select>
                                </label>
                            }

                            @* Color (cubiertas/bancas/locker-frente) *@
                            @if (EsFamilia(l, "CUBIERTAS") || EsFamilia(l, "BANCAS") || EsFamilia(l, "LOCKERS") && prod.TipoPrecio != "m2" && !prod.EsExtra)
                            {
                                @if (EsFamilia(l, "CUBIERTAS") && l.ColorEspecial)
                                {
                                    <label>Color especial<input @bind="l.ColorEspecialNombre" @bind:after="() => OnColorChanged(l)" placeholder="Escribe el color" /></label>
                                }
                                else
                                {
                                    <label>Color
                                        <select @bind="l.ColorNombre" @bind:after="() => OnColorChanged(l)">
                                            <option value="">—</option>
                                            @foreach (var c in ColoresDe(l))
                                            { <option value="@c.Nombre">@c.Nombre (@c.Grupo)@(c.TiempoEspecial ? " ·tiempo esp." : "")</option> }
                                        </select>
                                    </label>
                                }
                                @if (EsFamilia(l, "CUBIERTAS"))
                                {
                                    <label class="chk"><input type="checkbox" @bind="l.ColorEspecial" @bind:after="() => OnColorChanged(l)" /> Color especial (+20%)</label>
                                }
                            }

                            @* Lockers: color interior + extras *@
                            @if (EsFamilia(l, "LOCKERS") && !prod.EsExtra)
                            {
                                <label>Color interior
                                    <select @bind="l.ColorInterior" @bind:after="StateHasChanged">
                                        <option value="">@(ColorRegion == "MXN" ? "Alúmina" : "Gris") (estándar)</option>
                                        @foreach (var c in ColoresInterior())
                                        { <option value="@c.Nombre">@c.Nombre</option> }
                                    </select>
                                </label>
                            }
                        </div>

                        @* Extras de locker (se suman al precio) *@
                        @if (EsFamilia(l, "LOCKERS") && !prod.EsExtra)
                        {
                            <div class="extras">
                                <b>Extras (se suman al precio):</b>
                                <div class="extras-grid">
                                    @foreach (var ex in Extras())
                                    {
                                        var sel = l.ExtrasCant.ContainsKey(ex.ProductoId);
                                        <div class="extra-item">
                                            <label class="chk">
                                                <input type="checkbox" checked="@sel"
                                                       @onchange="e => ToggleExtra(l, ex.ProductoId, (bool)e.Value!)" />
                                                @ex.Nombre (@Money(PrecioExtra(ex, TierDe(prod))))
                                            </label>
                                            @if (sel)
                                            {
                                                <span class="extra-cant-wrap">×
                                                    <input class="extra-cant" type="number" min="1" step="1"
                                                           value="@l.ExtrasCant[ex.ProductoId]"
                                                           @onchange="e => SetExtraCant(l, ex.ProductoId, e.Value?.ToString())" />
                                                </span>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        @* Cubiertas: canto (sin costo) + perforación (sin costo) + grabado láser ($120 c/u) *@
                        @if (EsFamilia(l, "CUBIERTAS"))
                        {
                            <div class="renglon-opts">
                                <label class="mini">Canto
                                    <select @bind="l.Canto" @bind:after="() => OnColorChanged(l)">
                                        <option value="">—</option>
                                        <option value="A">A</option><option value="B">B</option>
                                        <option value="C">C</option><option value="D">D</option>
                                    </select>
                                </label>
                                <label class="chk"><input type="checkbox" @bind="l.Perforacion" @bind:after="() => OnColorChanged(l)" /> Perforación (sin costo)</label>
                                @if (l.Perforacion)
                                { <label class="mini">Cant. perforación<input type="number" min="1" step="1" @bind="l.PerforacionCant" @bind:after="() => OnColorChanged(l)" /></label> }
                                <label class="chk"><input type="checkbox" @bind="l.Grabado" @bind:after="() => OnColorChanged(l)" /> Grabado láser x cubierta ($120)</label>
                                @if (l.Grabado)
                                { <label class="mini">Cant. grabado<input type="number" min="1" step="1" @bind="l.GrabadoCant" @bind:after="() => OnColorChanged(l)" /></label> }
                            </div>
                        }
                        @if (EsFamilia(l, "BANCAS"))
                        {
                            <div class="renglon-opts">
                                <label class="chk"><input type="checkbox" @bind="l.Grabado" @bind:after="() => OnColorChanged(l)" /> Grabado láser x banca ($120)</label>
                                @if (l.Grabado)
                                { <label class="mini">Cant. grabado<input type="number" min="1" step="1" @bind="l.GrabadoCant" @bind:after="() => OnColorChanged(l)" /></label> }
                            </div>
                        }

                        <label class="desc">Descripción (va al PDF)
                            <textarea rows="3" @bind="l.Descripcion"></textarea>
                        </label>
                        <div class="renglon-importe">
                            P. unitario: <b>@Money(PrecioUnit(l))</b> · Importe: <b>@Money(Importe(l))</b>
                            <button class="btn-mini xls" @onclick="() => RegenerarDescripcion(l)">Regenerar descripción</button>
                        </div>
                    }
                </div>
            }
            @if (lineas.Count == 0) { <p class="muted">Sin renglones. Agrega el primero.</p> }
        </section>

        <!-- CIERRE: datos bancarios (izquierda) + totales (derecha) -->
        <div class="cot-cierre">
        <section class="card datos-banco">
            <h2>Datos bancarios del distribuidor</h2>
            <p class="muted small">Texto libre; sale en el PDF.</p>
            <textarea @bind="cot.DatosBancarios" rows="6" placeholder="Nombre, Banco, Cuenta, CLABE"></textarea>
        </section>
        <section class="card totales">
            <h2>Totales <span class="muted" style="font-size:.8rem">(@MonedaActual@(RegionActual=="LATAM" ? $" · ÷{Catalogo.DivisorUsd:0.##}" : ""))</span></h2>
            <div class="campos" style="margin-bottom:.8rem">
                <label>Gastos indirectos<input type="number" step="0.01" @bind="cot.GastosIndirectos" @bind:after="StateHasChanged" /></label>
                <label>Gastos de envío<input type="number" step="0.01" @bind="cot.GastosEnvio" @bind:after="StateHasChanged" /></label>
            </div>
            @{ var t = MotorPrecios.Calcular(ArmarCotizacion()); }
            <table class="tot">
                <tr><td>Subtotal público</td><td class="num">@Money(t.Subtotal)</td></tr>
                <tr><td>Descuentos</td><td class="num desc">-@Money(t.DescuentoMonto)</td></tr>
                <tr><td>Subtotal con descuento</td><td class="num">@Money(t.SubtotalDesc)</td></tr>
                @if (t.GastosIndirectos > 0) { <tr><td>Gastos indirectos</td><td class="num">@Money(t.GastosIndirectos)</td></tr> }
                @if (t.GastosEnvio > 0) { <tr><td>Gastos de envío</td><td class="num">@Money(t.GastosEnvio)</td></tr> }
                <tr><td>IVA (@cot.IvaPct.ToString("0.#")%)</td><td class="num">@Money(t.IvaMonto)</td></tr>
                <tr class="gran"><td>GRAN TOTAL</td><td class="num">@Money(t.GranTotal)</td></tr>
                <tr><td>Anticipo (@cot.AnticipoPct.ToString("0.#")%)</td><td class="num">@Money(t.Anticipo)</td></tr>
                <tr><td>Saldo</td><td class="num">@Money(t.Saldo)</td></tr>
            </table>
            @if (mensaje is not null) { <div class="aviso @(mensajeOk ? "ok" : "err")">@mensaje</div> }
            <button class="btn-guardar" @onclick="Guardar" disabled="@guardando">@(guardando ? "Guardando…" : "Descargar PDF Distribuidor (guardar)")</button>
            <button class="btn-pdf" @onclick="() => DescargarPdf(false)">Descargar PDF Cliente</button>
            <p class="muted small">El PDF Distribuidor lleva descuentos. El PDF Cliente va a precio público.</p>
        </section>
        </div>
    </div>
}

@code {
    private bool cargando = true, guardando;
    private string? mensaje; private bool mensajeOk;
    private Cotizacion cot = new();
    private DateTime? vigencia;
    private string entrega = "1 semana";
    private long distribuidorId;
    private string fabricacion = "México";
    private string monedaSel = "MXN";   // MXN | USD | CRC — la elige Admin/Vendedor a mano (indep. del distribuidor)
    private readonly List<LineaUI> lineas = new();

    private PDistribuidor? DistribActual => Catalogo.Distribuidores.FirstOrDefault(d => d.DistribuidorId == distribuidorId);
    private string nombreDistribuidorActual => DistribActual?.Nombre ?? "(sin asignar)";
    private string RegionActual => DistribActual?.Region ?? "México";
    private string MonedaActual => monedaSel;
    private decimal Divisor => Catalogo.DivisorUsd <= 0 ? 17m : Catalogo.DivisorUsd;
    private decimal Factor => monedaSel switch
    {
        "USD" => 1m / Divisor,
        "CRC" => (1m / Divisor) * (Catalogo.MultiplicadorCrc <= 0 ? 490m : Catalogo.MultiplicadorCrc),
        _ => 1m   // MXN
    };
    private static string MonedaDeRegion(string region) => region switch { "LATAM" => "USD", "Costa Rica" => "CRC", _ => "MXN" };
    private static decimal IvaDeMoneda(string m) => m switch { "MXN" => 16m, "CRC" => 13m, _ => 0m };
    // Los colores dependen del LUGAR DE FABRICACIÓN: México → paleta MXN; Costa Rica → paleta LATAM.
    private string ColorRegion => fabricacion == "México" ? "MXN" : "LATAM";

    [Parameter] public long? CotId { get; set; }
    private long? editandoId;
    private string? snapshot;   // estado al abrir para editar; si no cambia, no se crea variante

    // Serializa el estado editable normalizando el folio (para comparar sin la letra de variante).
    private string EstadoJson()
    {
        var folioPrev = cot.Folio; var lineasPrev = cot.Lineas;
        cot.Folio = ""; cot.Lineas = new();
        var est = new EstadoCot { DistribuidorId = distribuidorId, Vigencia = vigencia, Entrega = entrega, Fabricacion = fabricacion, MonedaSel = monedaSel, Header = cot, Lineas = lineas };
        var json = System.Text.Json.JsonSerializer.Serialize(est);
        cot.Folio = folioPrev; cot.Lineas = lineasPrev;
        return json;
    }

    protected override async Task OnInitializedAsync()
    {
        await Catalogo.CargarAsync();
        if (CotId is long id) { await CargarParaEditar(id); cargando = false; return; }
        cot.Folio = "";   // se asigna el consecutivo al guardar
        cot.CotizadoPor = Auth.Perfil?.Nombre;
        if (!Auth.PuedeVerTodo && Auth.Perfil?.DistribuidorId is long d) { distribuidorId = d; OnDistribuidorChanged(); }
        AgregarLinea();
        cargando = false;
    }

    private async Task CargarParaEditar(long id)
    {
        try
        {
            var c = await Supa.From<PCotizacion>().Where(x => x.CotizacionId == id).Single();
            if (c is null) { AgregarLinea(); return; }
            editandoId = id;
            // Encabezado desde la fila (funciona aunque no haya app_json)
            cot.Folio = c.Folio; cot.RazonSocial = c.RazonSocial; cot.Proyecto = c.Proyecto; cot.Titulo = c.Titulo;
            cot.Cliente = c.Cliente; cot.AtencionA = c.AtencionA; cot.Telefono = c.Telefono; cot.Ciudad = c.Ciudad;
            cot.CotizadoPor = c.CotizadoPor; cot.Comentarios = c.Comentarios;
            cot.DescuentoPct = c.DescuentoPct; cot.IvaPct = c.IvaPct; cot.AnticipoPct = c.AnticipoPct;
            cot.GastosIndirectos = c.GastosIndirectos; cot.GastosEnvio = c.GastosEnvio; cot.DatosBancarios = c.DatosBancarios;
            vigencia = c.Vigencia; distribuidorId = c.DistribuidorId ?? 0; fabricacion = c.Fabricacion ?? "México";
            if (!string.IsNullOrWhiteSpace(c.Entrega)) entrega = c.Entrega!;
            if (!string.IsNullOrWhiteSpace(c.Moneda)) monedaSel = c.Moneda!;

            if (!string.IsNullOrWhiteSpace(c.AppJson))
            {
                var est = System.Text.Json.JsonSerializer.Deserialize<EstadoCot>(c.AppJson!);
                if (est is not null)
                {
                    distribuidorId = est.DistribuidorId; vigencia = est.Vigencia; fabricacion = est.Fabricacion ?? "México";
                    if (!string.IsNullOrWhiteSpace(est.Entrega)) entrega = est.Entrega!;
                    if (!string.IsNullOrWhiteSpace(est.MonedaSel)) monedaSel = est.MonedaSel!;
                    cot = est.Header ?? cot; cot.Lineas = new();
                    cot.Folio = c.Folio;   // el folio autoritativo es el de la fila (el del estado va vacío)
                    lineas.Clear(); lineas.AddRange(est.Lineas);
                }
            }
            else
            {
                // Respaldo (cotizaciones viejas sin estado): reconstruye renglones básicos
                var filas = (await Supa.From<PCotizacionLinea>().Where(x => x.CotizacionId == id)
                                       .Order("orden", Supabase.Postgrest.Constants.Ordering.Ascending).Get()).Models;
                lineas.Clear();
                foreach (var f in filas)
                {
                    var prod = f.ProductoId is long pid ? Catalogo.Buscar(pid) : null;
                    lineas.Add(new LineaUI
                    {
                        FamiliaCodigo = prod?.FamiliaCodigo, ProductoId = f.ProductoId, Cantidad = f.Cantidad,
                        LargoCm = f.LargoCm, AnchoCm = f.AnchoCm, ColorNombre = f.Color ?? "",
                        DescuentoPct = f.DescuentoPct, Descripcion = f.Descripcion ?? "",
                    });
                }
            }
        }
        catch (Exception ex) { Aviso("No se pudo abrir la cotización: " + ex.Message, false); }
        if (lineas.Count == 0) AgregarLinea();
        snapshot = EstadoJson();   // referencia para saber si luego hubo cambios
    }

    private sealed class EstadoCot
    {
        public long DistribuidorId { get; set; }
        public DateTime? Vigencia { get; set; }
        public string? Entrega { get; set; }
        public string Fabricacion { get; set; } = "México";
        public string? MonedaSel { get; set; }
        public Cotizacion Header { get; set; } = new();
        public List<LineaUI> Lineas { get; set; } = new();
    }

    // ---------- catálogo / filtros ----------
    private Producto? ProdDe(LineaUI l) => l.ProductoId is long id ? Catalogo.Buscar(id) : null;
    private bool EsFamilia(LineaUI l, string fam) => l.FamiliaCodigo == fam;
    private IEnumerable<Producto> ProductosPrincipales(string? fam) =>
        Catalogo.PorFamilia(fam ?? "").Where(p => !p.EsExtra);
    private IEnumerable<Producto> Extras() =>
        Catalogo.PorFamilia("LOCKERS").Where(p => p.EsExtra).OrderBy(p => p.Orden);

    private IEnumerable<PColor> ColoresDe(LineaUI l)
    {
        var amb = EsFamilia(l, "CUBIERTAS") ? (l.Exterior ? "cubierta_ext" : "cubierta_int")
                : EsFamilia(l, "BANCAS") ? "banca"
                : EsFamilia(l, "LOCKERS") ? "locker_frente" : null;
        if (amb is null) return Enumerable.Empty<PColor>();
        return Catalogo.Colores.Where(c => c.Ambito == amb && c.Region == ColorRegion);
    }

    private string TierDe(Producto p) => (p.CodigoSap.StartsWith("L-") || p.CodigoSap.Contains("SMART")) ? "SMART" : "PRO";

    private decimal PrecioExtra(Producto ex, string tier)
    {
        if (ex.Precios.TryGetValue(tier, out var pt)) return pt;
        if (ex.Precios.TryGetValue("UNICO", out var pu)) return pu;
        return ex.Precios.Values.FirstOrDefault();
    }

    // ---------- grupo / precio ----------
    private string GrupoEfectivo(LineaUI l, Producto p)
    {
        if (EsFamilia(l, "CUBIERTAS"))
        {
            if (l.ColorEspecial) return l.Exterior ? "G4" : "G1";
            var col = Catalogo.Colores.FirstOrDefault(c => c.Nombre == l.ColorNombre && c.Ambito == (l.Exterior ? "cubierta_ext" : "cubierta_int"));
            return col?.Grupo ?? (l.Exterior ? "G4" : "G1");
        }
        if (EsFamilia(l, "BANCAS")) return "G1";
        if (EsFamilia(l, "LOCKERS") && p.TipoPrecio == "m2") return string.IsNullOrEmpty(l.Grupo) ? p.Precios.Keys.FirstOrDefault() ?? "UNICO" : l.Grupo;
        return p.Precios.ContainsKey("UNICO") ? "UNICO" : p.Precios.Keys.FirstOrDefault() ?? "UNICO";
    }

    private decimal PrecioUnit(LineaUI l)
    {
        var p = ProdDe(l); if (p is null) return 0m;
        var grupo = GrupoEfectivo(l, p);
        decimal precio = p.Precios.GetValueOrDefault(grupo, p.Precios.Values.FirstOrDefault());
        if (p.TipoPrecio == "m2")
        {
            decimal a = (l.LargoCm ?? 0) / 100m;
            decimal b = p.MedidaUnica ? a : (l.AnchoCm ?? 0) / 100m;   // redonda/cuadrada: área = medida²
            precio *= a * b;
        }
        if (EsFamilia(l, "CUBIERTAS") && l.ColorEspecial) precio *= 1.20m;
        // Grabado láser en cubiertas/bancas: $120 por pieza grabada (sin descuento de línea; se suma al unitario)
        if ((EsFamilia(l, "CUBIERTAS") || EsFamilia(l, "BANCAS")) && l.Grabado) precio += 120m * Math.Max(1, l.GrabadoCant);
        // (El color interior de locker ya NO agrega recargo: Blanco/Negro van sin +10%.)
        if (EsFamilia(l, "LOCKERS") && !p.EsExtra)
            foreach (var kv in l.ExtrasCant)
                if (Catalogo.Buscar(kv.Key) is Producto ex) precio += PrecioExtra(ex, TierDe(p)) * kv.Value;
        return precio * Factor;   // LATAM: ÷ divisor (USD); MXN: ×1
    }

    private decimal Importe(LineaUI l) => l.Cantidad * PrecioUnit(l);

    // ---------- eventos ----------
    private void AgregarLinea() => lineas.Add(new LineaUI());
    private void QuitarLinea(LineaUI l) { lineas.Remove(l); StateHasChanged(); }

    private void OnFamiliaChanged(LineaUI l)
    {
        l.ProductoId = null; l.Grupo = ""; l.Descripcion = ""; l.LargoCm = l.AnchoCm = null;
        l.ColorNombre = l.ColorInterior = l.ColorEspecialNombre = ""; l.ColorEspecial = false; l.Exterior = false; l.ExtrasCant.Clear();
        l.Canto = ""; l.Perforacion = false; l.PerforacionCant = 1; l.Grabado = false; l.GrabadoCant = 1;
        StateHasChanged();
    }
    private void OnProductoChanged(LineaUI l)
    {
        var p = ProdDe(l);
        if (p is not null)
        {
            l.Grupo = p.Precios.Keys.FirstOrDefault() ?? "UNICO";
            // descuento base según la familia del producto y el distribuidor
            if (distribuidorId != 0 && p.AplicaDescuento) l.DescuentoPct = Catalogo.DescuentoFamilia(distribuidorId, l.FamiliaCodigo);
            RegenerarDescripcion(l);
        }
        StateHasChanged();
    }
    private void OnColorChanged(LineaUI l) { ClampG4(l); RegenerarDescripcion(l); StateHasChanged(); }
    private void OnTipoChanged(LineaUI l) { l.ColorNombre = ""; ClampG4(l); RegenerarDescripcion(l); StateHasChanged(); }

    // Al cambiar el lugar de fabricación cambia la paleta de colores: se limpian los colores elegidos.
    private void OnFabricacionChanged()
    {
        foreach (var l in lineas) { l.ColorNombre = ""; l.ColorInterior = ""; RegenerarDescripcion(l); }
        StateHasChanged();
    }

    // Admin/Vendedor cambia la moneda a mano: ajusta el IVA default (editable) y recalcula.
    private void OnMonedaChanged() { cot.IvaPct = IvaDeMoneda(monedaSel); StateHasChanged(); }

    // Cubiertas REDONDAS de exterior (grupo G4): el diámetro máximo es 120 cm. Se limita y se avisa.
    private const decimal MaxG4Cm = 120m;
    private bool EsRedondaG4(LineaUI l)
    {
        var p = ProdDe(l);
        return p is not null && EsFamilia(l, "CUBIERTAS") && p.CodigoSap.StartsWith("CR") && GrupoEfectivo(l, p) == "G4";
    }
    private string? MaxMedida(LineaUI l) => EsRedondaG4(l) ? "120" : null;
    private void ClampG4(LineaUI l)
    {
        if (!EsRedondaG4(l)) { l.Aviso = null; return; }
        bool ajustado = false;
        if (l.LargoCm > MaxG4Cm) { l.LargoCm = MaxG4Cm; ajustado = true; }
        l.Aviso = ajustado ? "En redonda de exterior (G4) el diámetro máximo es 120 cm; se ajustó a 120." : null;
    }
    private void OnDistribuidorChanged()
    {
        var d = DistribActual;
        if (d is not null)
        {
            cot.DescuentoPct = 0m;   // "descuento adicional" global (solo admin); base va por familia en cada renglón
            if (!Auth.PuedeVerTodo) monedaSel = MonedaDeRegion(RegionActual); // distribuidor: moneda fija por su región
            cot.IvaPct = IvaDeMoneda(monedaSel);   // IVA default según la moneda (editable)
            fabricacion = RegionActual == "México" ? "México" : "Costa Rica"; // default: colores según fabricación
            if (string.IsNullOrWhiteSpace(cot.RazonSocial)) cot.RazonSocial = d.Nombre;
            // Aplica el descuento por familia a cada renglón; y el cambio de región invalida colores
            foreach (var l in lineas)
            {
                l.ColorNombre = ""; l.ColorInterior = "";
                var p = ProdDe(l);
                if (p is not null && p.AplicaDescuento) l.DescuentoPct = Catalogo.DescuentoFamilia(distribuidorId, l.FamiliaCodigo);
            }
        }
        StateHasChanged();
    }
    private void ToggleExtra(LineaUI l, long id, bool on)
    {
        if (on) l.ExtrasCant[id] = l.ExtrasCant.GetValueOrDefault(id, 1) is var q && q > 0 ? q : 1;
        else l.ExtrasCant.Remove(id);
        RegenerarDescripcion(l); StateHasChanged();
    }

    private void SetExtraCant(LineaUI l, long id, string? valor)
    {
        if (int.TryParse(valor, out var n) && n >= 1) l.ExtrasCant[id] = n;
        RegenerarDescripcion(l); StateHasChanged();
    }

    // Colores interior del locker con +10% (excluye el estándar: Alúmina en MX / Gris en CR)
    private IEnumerable<PColor> ColoresInterior() =>
        Catalogo.Colores.Where(c => c.Ambito == "locker_interior" && c.Region == ColorRegion
                                    && c.Nombre != "Alúmina" && c.Nombre != "Alumina" && c.Nombre != "Gris");

    // Color que va al PDF/descripción (especial escrito a mano, o el del catálogo)
    private string? ColorFinal(LineaUI l) =>
        EsFamilia(l, "CUBIERTAS") && l.ColorEspecial
            ? (string.IsNullOrWhiteSpace(l.ColorEspecialNombre) ? null : l.ColorEspecialNombre.Trim())
            : (string.IsNullOrEmpty(l.ColorNombre) ? null : l.ColorNombre);

    // ---------- descripción automática ----------
    private void RegenerarDescripcion(LineaUI l)
    {
        var p = ProdDe(l); if (p is null) return;
        var sb = new System.Text.StringBuilder(p.Descripcion);
        if (p.RequiereMedidas && (l.LargoCm > 0 || l.AnchoCm > 0))
        {
            string medida;
            if (p.MedidaUnica)
                medida = p.CodigoSap.StartsWith("CR") ? $"{l.LargoCm:0.#} CM DIÁMETRO" : $"{l.LargoCm:0.#} X {l.LargoCm:0.#} CM";
            else
                medida = $"{l.LargoCm:0.#} X {l.AnchoCm:0.#} CM";
            sb.Replace("__ CM DIÁMETRO", medida).Replace("__ CM X __ CM", medida).Replace("__ CM", medida).Replace("MEDIDA FINAL: __", $"MEDIDA FINAL: {medida}");
        }
        if (!string.IsNullOrEmpty(l.Canto)) sb.Replace("CANTO __", "CANTO " + l.Canto);
        var colorTxt = ColorFinal(l);
        if (!string.IsNullOrEmpty(colorTxt)) sb.Append($" COLOR: {colorTxt}.");
        if (!string.IsNullOrEmpty(l.ColorInterior)) sb.Append($" INTERIOR: {l.ColorInterior}.");
        if (l.Perforacion) sb.Append($" PERFORACIÓN: SÍ (x{Math.Max(1, l.PerforacionCant)}).");
        if ((EsFamilia(l, "CUBIERTAS") || EsFamilia(l, "BANCAS")) && l.Grabado) sb.Append($" GRABADO LÁSER (x{Math.Max(1, l.GrabadoCant)}).");
        if (EsFamilia(l, "LOCKERS") && l.ExtrasCant.Count > 0)
        {
            var nombres = l.ExtrasCant.Select(kv => { var n = Catalogo.Buscar(kv.Key)?.Nombre; return kv.Value > 1 ? $"{n} (x{kv.Value})" : n; }).Where(n => n != null);
            sb.Append(" INCLUYE: " + string.Join(", ", nombres) + ".");
        }
        l.Descripcion = sb.ToString();
    }

    // ---------- armar / guardar ----------
    private Cotizacion ArmarCotizacion()
    {
        cot.Lineas = lineas.Select(l =>
        {
            var p = ProdDe(l);
            return new LineaCotizacion
            {
                ProductoId = l.ProductoId, Cantidad = l.Cantidad, CodigoSap = p?.CodigoSap ?? "",
                Descripcion = l.Descripcion, Color = ColorFinal(l),
                LargoCm = l.LargoCm, AnchoCm = l.AnchoCm, PrecioUnitario = PrecioUnit(l),
                DescuentoPct = l.DescuentoPct, AplicaDescuento = p?.AplicaDescuento ?? true,
            };
        }).ToList();
        return cot;
    }

    private async Task Guardar()
    {
        mensaje = null;
        var conProducto = lineas.Where(l => l.ProductoId is not null).ToList();
        if (distribuidorId == 0) { Aviso("Selecciona un distribuidor.", false); return; }
        if (conProducto.Count == 0) { Aviso("Agrega al menos un renglón con producto.", false); return; }
        guardando = true;
        try
        {
            ArmarCotizacion();
            var t = MotorPrecios.Calcular(cot);

            // Estado completo del configurador (para reabrir/editar tal cual)
            cot.Lineas = new();
            var estado = new EstadoCot { DistribuidorId = distribuidorId, Vigencia = vigencia, Entrega = entrega, Fabricacion = fabricacion, MonedaSel = monedaSel, Header = cot, Lineas = lineas };
            var appJson = System.Text.Json.JsonSerializer.Serialize(estado);

            bool eraEdicion = editandoId is not null;

            // Si se abrió para editar y NO hubo cambios: mismo expediente, sin crear variante.
            if (eraEdicion && EstadoJson() == snapshot)
            {
                await DescargarPdf();
                Aviso($"Cotización {cot.Folio} descargada (sin cambios; mismo expediente).", true);
                return;
            }

            string folio;
            if (!eraEdicion)
            {
                // Toma el siguiente consecutivo vía función de servidor (atómico, sin chocar con RLS)
                var rpc = await Supa.Rpc("siguiente_folio", new Dictionary<string, object?>());
                var raw = (rpc?.Content ?? "").Trim().Trim('"');
                folio = string.IsNullOrEmpty(raw) ? Catalogo.FolioConsecutivo.ToString() : raw;
            }
            else
            {
                var baseF = FolioBase(cot.Folio ?? "");
                var existentes = (await Supa.From<PCotizacion>()
                    .Filter("folio", Supabase.Postgrest.Constants.Operator.Like, baseF + "%").Get())
                    .Models.Select(x => x.Folio).ToList();
                folio = SiguienteVariante(baseF, existentes);
            }
            var pcot = new PCotizacion
            {
                Folio = folio, Fecha = DateTime.UtcNow,
                Vigencia = vigencia, RazonSocial = cot.RazonSocial, Proyecto = cot.Proyecto, Titulo = cot.Titulo,
                Cliente = cot.Cliente, AtencionA = cot.AtencionA, Telefono = cot.Telefono, Ciudad = cot.Ciudad,
                CotizadoPor = cot.CotizadoPor, DistribuidorId = distribuidorId, CreadoPor = Auth.Perfil?.Id,
                Estado = "borrador", Moneda = MonedaActual,
                TipoCambio = monedaSel == "MXN" ? 1m : Catalogo.DivisorUsd, DescuentoPct = cot.DescuentoPct,
                IvaPct = cot.IvaPct, AnticipoPct = cot.AnticipoPct, Comentarios = cot.Comentarios,
                Subtotal = t.Subtotal, DescuentoMonto = t.DescuentoMonto, SubtotalDesc = t.SubtotalDesc,
                IvaMonto = t.IvaMonto, GranTotal = t.GranTotal, AnticipoMonto = t.Anticipo, SaldoMonto = t.Saldo,
                AppJson = appJson, Fabricacion = fabricacion, Entrega = entrega,
                GastosIndirectos = cot.GastosIndirectos, GastosEnvio = cot.GastosEnvio, DatosBancarios = cot.DatosBancarios,
            };

            // Siempre inserta: una edición se guarda como VARIANTE nueva (el original queda intacto).
            var resp = await Supa.From<PCotizacion>().Insert(pcot);
            var cotId = resp.Models.First().CotizacionId;

            var filas = new List<PCotizacionLinea>(); int orden = 1;
            foreach (var l in conProducto)
            {
                var p = ProdDe(l)!;
                filas.Add(new PCotizacionLinea
                {
                    CotizacionId = cotId, Orden = orden++, ProductoId = l.ProductoId, Cantidad = l.Cantidad,
                    CodigoSap = p.CodigoSap, Descripcion = l.Descripcion, Color = ColorFinal(l),
                    LargoCm = l.LargoCm, AnchoCm = l.AnchoCm, PrecioUnitario = PrecioUnit(l), DescuentoPct = l.DescuentoPct,
                    AplicaDescuento = p.AplicaDescuento, Subtotal = MotorPrecios.R(Importe(l)),
                });
            }
            await Supa.From<PCotizacionLinea>().Insert(filas);
            editandoId = cotId; cot.Folio = folio;
            snapshot = EstadoJson();   // nuevo punto de referencia: re-descargar sin cambios no crea otra variante
            await DescargarPdf();
            await Catalogo.CargarAsync(forzar: true);   // refresca el consecutivo para la próxima cotización
            Aviso($"Cotización {folio} {(eraEdicion ? "guardada como variante (el original queda intacto)" : "guardada")} y PDF descargado.", true);
        }
        catch (Exception ex) { Aviso("No se pudo guardar: " + ex.Message, false); }
        finally { guardando = false; }
    }

    private void Aviso(string m, bool ok) { mensaje = m; mensajeOk = ok; }

    // Folio base (sin la letra de variante) y siguiente variante disponible (B, C, D…)
    private static string FolioBase(string f) =>
        (f.Length >= 2 && f[^2] == '-' && char.IsLetter(f[^1])) ? f[..^2] : f;

    private static string SiguienteVariante(string baseF, List<string> existentes)
    {
        var usadas = existentes.Where(x => !string.IsNullOrEmpty(x) && x.StartsWith(baseF + "-"))
                               .Select(x => x[(baseF.Length + 1)..]).ToHashSet();
        for (char c = 'B'; c <= 'Z'; c++)
            if (!usadas.Contains(c.ToString())) return $"{baseF}-{c}";
        return $"{baseF}-{DateTime.Now:HHmmss}";
    }
    // Símbolo por moneda: Colones → ₡ ; Pesos/Dólares → $
    private string Money(decimal v) => (MonedaActual == "CRC" ? "₡" : "$") + v.ToString("#,##0.00");

    // conDescuento=true -> PDF DISTRIBUIDOR (con descuentos, se guarda/va al Excel); false -> PDF CLIENTE (precio público)
    private async Task DescargarPdf(bool conDescuento = true)
    {
        ArmarCotizacion();
        Totales t;
        if (conDescuento)
            t = MotorPrecios.Calcular(cot);
        else
        {
            var sin = new Cotizacion { IvaPct = cot.IvaPct, AnticipoPct = cot.AnticipoPct, DescuentoPct = 0m,
                GastosIndirectos = cot.GastosIndirectos, GastosEnvio = cot.GastosEnvio,
                Lineas = cot.Lineas.Select(l => new LineaCotizacion { Cantidad = l.Cantidad, PrecioUnitario = l.PrecioUnitario, AplicaDescuento = false }).ToList() };
            t = MotorPrecios.Calcular(sin);
        }
        bool hayInstalacion = lineas.Any(l => ProdDe(l)?.CodigoSap.StartsWith("INST-") == true);
        bool hayFlete = lineas.Any(l => ProdDe(l)?.CodigoSap.StartsWith("FLETE") == true);
        var dto = new
        {
            folio = cot.Folio, vigencia = vigencia?.ToString("dd/MM/yyyy") ?? "", entrega = entrega,
            razonSocial = cot.RazonSocial, proyecto = cot.Proyecto, titulo = cot.Titulo, cliente = cot.Cliente,
            atencionA = cot.AtencionA, telefono = cot.Telefono, ciudad = cot.Ciudad, cotizadoPor = cot.CotizadoPor,
            comentarios = cot.Comentarios, descuentoPct = cot.DescuentoPct.ToString("0.#"),
            ivaPct = cot.IvaPct.ToString("0.#"), anticipoPct = (double)cot.AnticipoPct,
            datosBancarios = cot.DatosBancarios,
            moneda = MonedaActual, mostrarDescuento = conDescuento, tipoPdf = conDescuento ? "DISTRIBUIDOR" : "CLIENTE",
            incluyeInstalacion = hayInstalacion, incluyeFlete = hayFlete,
            totales = new { subtotal = (double)t.Subtotal, descuentoMonto = (double)t.DescuentoMonto, subtotalDesc = (double)t.SubtotalDesc,
                gastosIndirectos = (double)t.GastosIndirectos, gastosEnvio = (double)t.GastosEnvio,
                ivaMonto = (double)t.IvaMonto, granTotal = (double)t.GranTotal, anticipo = (double)t.Anticipo, saldo = (double)t.Saldo },
            lineas = lineas.Where(l => l.ProductoId is not null).Select(l => new
            {
                cantidad = (double)l.Cantidad, codigoSap = ProdDe(l)?.CodigoSap ?? "", descripcion = l.Descripcion,
                color = ColorFinal(l), precioUnitario = (double)PrecioUnit(l), importe = (double)Importe(l),
            }).ToArray(),
        };
        await JS.InvokeVoidAsync("cotizadorPdf.generar", dto);
    }

    private sealed class LineaUI
    {
        public string? FamiliaCodigo { get; set; }
        public long? ProductoId { get; set; }
        [System.Text.Json.Serialization.JsonIgnore]
        public string ProductoIdStr { get => ProductoId?.ToString() ?? ""; set => ProductoId = long.TryParse(value, out var v) ? v : null; }
        public string Grupo { get; set; } = "";
        public decimal Cantidad { get; set; } = 1;
        public decimal? LargoCm { get; set; }
        public decimal? AnchoCm { get; set; }
        public decimal DescuentoPct { get; set; }
        public string ColorNombre { get; set; } = "";
        public string ColorEspecialNombre { get; set; } = "";
        public string ColorInterior { get; set; } = "";
        public bool ColorEspecial { get; set; }
        public bool Exterior { get; set; }
        public string Canto { get; set; } = "";
        public bool Perforacion { get; set; }
        public int PerforacionCant { get; set; } = 1;
        public bool Grabado { get; set; }
        public int GrabadoCant { get; set; } = 1;
        [System.Text.Json.Serialization.JsonIgnore]
        public string TipoStr { get => Exterior ? "Exterior" : "Interior"; set => Exterior = value == "Exterior"; }
        public string Descripcion { get; set; } = "";
        public Dictionary<long, int> ExtrasCant { get; set; } = new();  // extraId -> cantidad
        [System.Text.Json.Serialization.JsonIgnore]
        public string? Aviso { get; set; }   // p.ej. límite de medida en G4 (no se persiste)
    }
