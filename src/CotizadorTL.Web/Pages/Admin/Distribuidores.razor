@page "/admin/distribuidores"
@inject AuthService Auth
@inject CatalogoService Catalogo
@inject Supabase.Client Supa
@inject NavigationManager Nav

<PageTitle>Distribuidores</PageTitle>

@if (!Auth.PuedeVerTodo)
{
    <p>No tienes acceso a esta sección.</p>
}
else if (cargando)
{
    <p>Cargando…</p>
}
else
{
    <h1>Distribuidores</h1>

    <!-- ===== Cuentas de distribuidores (auto-registro) ===== -->
    <section class="card">
        <h2>Cuentas de distribuidores</h2>
        <p class="muted small">Los distribuidores se inscriben solos. Asígnales su <b>empresa</b> y <b>actívalos</b> para que puedan entrar.</p>
        <div class="tabla-wrap">
            <table class="proyectos">
                <thead><tr><th>Nombre</th><th>Email</th><th>Empresa</th><th>Estado</th><th></th></tr></thead>
                <tbody>
                    @foreach (var u in cuentas)
                    {
                        <tr>
                            <td>@u.Nombre</td>
                            <td>@u.Email</td>
                            <td>
                                <select @bind="u.DistribuidorIdStr">
                                    <option value="">— Asignar empresa —</option>
                                    @foreach (var d in Catalogo.Distribuidores)
                                    { <option value="@d.DistribuidorId">@d.Nombre</option> }
                                </select>
                            </td>
                            <td>
                                @if (u.Activo) { <span class="estado" style="background:var(--tl-lima-bg);color:var(--tl-verde-txt)">Activo</span> }
                                else { <span class="estado" style="background:#fdecea;color:#b03030">Pendiente</span> }
                            </td>
                            <td class="acciones">
                                <button class="btn-mini xls" @onclick="() => GuardarCuenta(u)">@(u.Activo ? "Guardar" : "Autorizar")</button>
                                @if (u.Activo)
                                { <button class="btn-mini pdf" @onclick="() => DesactivarCuenta(u)">Desactivar</button> }
                            </td>
                        </tr>
                    }
                    @if (cuentas.Count == 0)
                    { <tr><td colspan="5" class="muted center">No hay cuentas de distribuidores todavía.</td></tr> }
                </tbody>
            </table>
        </div>
        @if (msgU is not null) { <div class="aviso @(okU ? "ok" : "err")">@msgU</div> }
    </section>

    <!-- ===== Empresas distribuidoras (alta/edición: solo Admin/Super) ===== -->
    @if (Auth.EsAdmin)
    {
    <section class="card">
        <h2>@(edit.DistribuidorId == 0 ? "Nueva empresa distribuidora" : "Editar empresa")</h2>
        <div class="campos">
            <label>Nombre<input @bind="edit.Nombre" /></label>
            <label>País<input @bind="edit.Pais" /></label>
            <label>Región (define moneda y precio)
                <select @bind="edit.Region">
                    <option value="México">México (MXN)</option>
                    <option value="LATAM">LATAM (USD)</option>
                    <option value="Costa Rica">Costa Rica (colones)</option>
                </select>
            </label>
            <label>Teléfono<input @bind="edit.Telefono" /></label>
            <label>Ubicación / ciudad<input @bind="edit.Ubicacion" /></label>
            <label>Descuento por defecto %<input type="number" step="0.01" @bind="edit.DescuentoPct" /></label>
        </div>
        @if (edit.DistribuidorId != 0)
        {
            <p class="muted small" style="margin:.6rem 0 .2rem"><b>Descuentos por familia</b> (si quedan en 0, se usa el descuento por defecto):</p>
            <div class="campos">
                <label>Cubiertas %<input type="number" step="0.01" @bind="descCub" /></label>
                <label>Lockers %<input type="number" step="0.01" @bind="descLock" /></label>
                <label>Bancas %<input type="number" step="0.01" @bind="descBanca" /></label>
            </div>
        }
        <button class="btn-add" @onclick="GuardarEmpresa" disabled="@guardando">
            @(guardando ? "Guardando…" : (edit.DistribuidorId == 0 ? "Agregar" : "Guardar cambios"))
        </button>
        @if (edit.DistribuidorId != 0)
        { <button class="btn-pdf" style="width:auto;margin-left:.5rem" @onclick="NuevoForm">Cancelar edición</button> }
        @if (msg is not null) { <div class="aviso @(ok ? "ok" : "err")">@msg</div> }
    </section>
    }

    <section class="card">
        <h2>Empresas</h2>
        <div class="tabla-wrap">
            <table class="proyectos">
                <thead><tr><th>Nombre</th><th>País</th><th>Región</th><th>Ubicación</th><th class="num">Desc. %</th><th></th></tr></thead>
                <tbody>
                    @foreach (var d in Catalogo.Distribuidores)
                    {
                        <tr>
                            <td><b>@d.Nombre</b></td><td>@d.Pais</td>
                            <td><span class="estado">@d.Region</span></td><td>@d.Ubicacion</td>
                            <td class="num">@d.DescuentoPct.ToString("0.#")</td>
                            <td class="acciones">
                                @if (Auth.EsAdmin)
                                { <button class="btn-mini xls" @onclick="() => Editar(d)">Editar</button> }
                                @if (Auth.EsSuper)
                                { <button class="btn-mini pdf" @onclick="() => Borrar(d)">Borrar</button> }
                            </td>
                        </tr>
                    }
                    @if (Catalogo.Distribuidores.Count == 0)
                    { <tr><td colspan="6" class="muted center">Sin empresas.</td></tr> }
                </tbody>
            </table>
        </div>
    </section>
}

@code {
    private bool cargando = true, guardando;
    private string? msg, msgU; private bool ok, okU;
    private PDistribuidor edit = new();
    private readonly List<CuentaVM> cuentas = new();

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.PuedeVerTodo) { Nav.NavigateTo(""); return; }
        await Catalogo.CargarAsync();
        await CargarCuentas();
        cargando = false;
    }

    private async Task CargarCuentas()
    {
        cuentas.Clear();
        var resp = await Supa.From<Profile>().Order("nombre", Supabase.Postgrest.Constants.Ordering.Ascending).Get();
        foreach (var p in resp.Models.Where(p => p.Rol == "Distribuidor"))
            cuentas.Add(new CuentaVM { Id = p.Id, Nombre = p.Nombre, Email = p.Email, DistribuidorId = p.DistribuidorId, Activo = p.Activo });
    }

    private async Task GuardarCuenta(CuentaVM u)
    {
        msgU = null;
        if (u.DistribuidorId is null) { okU = false; msgU = "Primero asigna una empresa al distribuidor."; return; }
        try
        {
            var p = new Profile { Id = u.Id, Nombre = u.Nombre, Email = u.Email, Rol = "Distribuidor", DistribuidorId = u.DistribuidorId, Activo = true };
            await Supa.From<Profile>().Update(p);
            u.Activo = true;
            var cerr = await Auth.ConfirmarUsuario(u.Id);   // confirma el correo (sin SQL) para que pueda entrar
            okU = true;
            msgU = cerr is null
                ? $"{u.Email} autorizado y confirmado. Ya puede entrar."
                : $"{u.Email} autorizado, pero no se pudo confirmar el correo automáticamente: {cerr}";
        }
        catch (Exception ex) { okU = false; msgU = "No se pudo guardar: " + ex.Message; }
    }

    private async Task DesactivarCuenta(CuentaVM u)
    {
        msgU = null;
        try
        {
            // No se borra: se conserva el correo y queda INACTIVO (pendiente). Se puede reactivar luego.
            var p = new Profile { Id = u.Id, Nombre = u.Nombre, Email = u.Email, Rol = "Distribuidor",
                                  DistribuidorId = u.DistribuidorId, Activo = false };
            await Supa.From<Profile>().Update(p);
            u.Activo = false;
            okU = true; msgU = $"{u.Email} desactivado. Queda pendiente; puedes reactivarlo con “Autorizar” cuando quieras.";
        }
        catch (Exception ex) { okU = false; msgU = "No se pudo desactivar: " + ex.Message; }
    }

    private void NuevoForm() { edit = new PDistribuidor(); msg = null; }

    private decimal descCub, descLock, descBanca;

    private async Task Editar(PDistribuidor d)
    {
        edit = new PDistribuidor { DistribuidorId = d.DistribuidorId, Nombre = d.Nombre, Email = d.Email, Telefono = d.Telefono, Ubicacion = d.Ubicacion, Pais = d.Pais, Region = d.Region, DescuentoPct = d.DescuentoPct, Activo = d.Activo };
        descCub = descLock = descBanca = 0;
        var rows = (await Supa.From<PDistribuidorDescuento>().Where(x => x.DistribuidorId == d.DistribuidorId).Get()).Models;
        foreach (var r in rows)
        {
            if (r.FamiliaCodigo == "CUBIERTAS") descCub = r.DescuentoPct;
            else if (r.FamiliaCodigo == "LOCKERS") descLock = r.DescuentoPct;
            else if (r.FamiliaCodigo == "BANCAS") descBanca = r.DescuentoPct;
        }
        msg = null;
    }

    private async Task GuardarEmpresa()
    {
        msg = null;
        if (string.IsNullOrWhiteSpace(edit.Nombre)) { ok = false; msg = "El nombre es obligatorio."; return; }
        guardando = true;
        try
        {
            var editingId = edit.DistribuidorId;
            if (editingId == 0) await Supa.From<PDistribuidor>().Insert(edit);
            else
            {
                await Supa.From<PDistribuidor>().Update(edit);
                // Descuentos por familia (solo se guardan los > 0; el resto usa el descuento por defecto)
                await Supa.From<PDistribuidorDescuento>().Where(x => x.DistribuidorId == editingId).Delete();
                var rows = new List<PDistribuidorDescuento>();
                if (descCub > 0) rows.Add(new() { DistribuidorId = editingId, FamiliaCodigo = "CUBIERTAS", DescuentoPct = descCub });
                if (descLock > 0) rows.Add(new() { DistribuidorId = editingId, FamiliaCodigo = "LOCKERS", DescuentoPct = descLock });
                if (descBanca > 0) rows.Add(new() { DistribuidorId = editingId, FamiliaCodigo = "BANCAS", DescuentoPct = descBanca });
                if (rows.Count > 0) await Supa.From<PDistribuidorDescuento>().Insert(rows);
            }
            await Catalogo.CargarAsync(forzar: true);
            ok = true; msg = "Empresa guardada."; NuevoForm();
        }
        catch (Exception ex) { ok = false; msg = "No se pudo guardar: " + ex.Message; }
        finally { guardando = false; }
    }

    private async Task Borrar(PDistribuidor d)
    {
        msg = null;
        try
        {
            await Supa.From<PDistribuidor>().Where(x => x.DistribuidorId == d.DistribuidorId).Delete();
            await Catalogo.CargarAsync(forzar: true);
            ok = true; msg = $"{d.Nombre} eliminada.";
        }
        catch (Exception ex) { ok = false; msg = "No se pudo borrar (¿tiene cotizaciones o usuarios?): " + ex.Message; }
    }

    private sealed class CuentaVM
    {
        public string Id { get; set; } = "";
        public string Nombre { get; set; } = "";
        public string? Email { get; set; }
        public long? DistribuidorId { get; set; }
        public bool Activo { get; set; }
        public string DistribuidorIdStr
        {
            get => DistribuidorId?.ToString() ?? "";
            set => DistribuidorId = long.TryParse(value, out var v) ? v : null;
        }
    }
}
