@page "/admin/usuarios"
@inject AuthService Auth
@inject Supabase.Client Supa
@inject NavigationManager Nav

<PageTitle>Usuarios</PageTitle>

@if (!Auth.EsSuper)
{
    <p>No tienes acceso a esta sección.</p>
}
else if (cargando)
{
    <p>Cargando…</p>
}
else
{
    <h1>Usuarios</h1>
    <p class="muted small">
        Solo <b>Administradores</b> y <b>Super Admin</b>. Los distribuidores se gestionan en la pestaña
        <b>Distribuidores</b>. Aquí el <b>Super Admin</b> crea las cuentas y les asigna el rol; también puede
        promover a Administrador o Vendedor a quien se haya auto-registrado.
    </p>

    <section class="card">
        <h2 class="sub">Crear usuario</h2>
        <div class="filtros">
            <label>Nombre<input @bind="nNombre" placeholder="Nombre y apellido" /></label>
            <label>Email<input type="email" @bind="nEmail" placeholder="correo@empresa.com" /></label>
            <label>Contraseña<input type="password" @bind="nPass" placeholder="mínimo 6 caracteres" /></label>
            <label>Rol
                <select @bind="nRol">
                    <option>Administrador</option>
                    <option>Vendedor</option>
                    <option>Super Admin</option>
                </select>
            </label>
            <button class="btn-add" disabled="@creando" @onclick="Crear">@(creando ? "Creando…" : "Crear")</button>
        </div>
        <p class="muted small">La cuenta queda activa de inmediato con el rol elegido.</p>
        @if (msgCrear is not null) { <div class="aviso @(okCrear ? "ok" : "err")">@msgCrear</div> }
    </section>

    <section class="card">
        <div class="tabla-wrap">
            <table class="proyectos">
                <thead><tr><th>Nombre</th><th>Email</th><th>Rol</th><th>Activo</th><th></th></tr></thead>
                <tbody>
                    @foreach (var u in usuarios)
                    {
                        <tr>
                            <td>@u.Nombre</td>
                            <td>@u.Email</td>
                            <td>
                                <select @bind="u.Rol">
                                    <option>Distribuidor</option>
                                    <option>Vendedor</option>
                                    <option>Administrador</option>
                                    <option>Super Admin</option>
                                </select>
                            </td>
                            <td><input type="checkbox" @bind="u.Activo" /></td>
                            <td><button class="btn-mini xls" @onclick="() => Guardar(u)">Guardar</button></td>
                        </tr>
                    }
                    @if (usuarios.Count == 0)
                    { <tr><td colspan="5" class="muted center">Sin administradores.</td></tr> }
                </tbody>
            </table>
        </div>
        @if (msg is not null) { <div class="aviso @(ok ? "ok" : "err")">@msg</div> }
    </section>
}

@code {
    private bool cargando = true;
    private string? msg; private bool ok;
    private readonly List<UsuarioVM> usuarios = new();

    // Alta de usuario
    private string nNombre = "", nEmail = "", nPass = "", nRol = "Administrador";
    private bool creando; private string? msgCrear; private bool okCrear;

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.EsSuper) { Nav.NavigateTo(""); return; }
        var resp = await Supa.From<Profile>()
                             .Order("nombre", Supabase.Postgrest.Constants.Ordering.Ascending).Get();
        foreach (var p in resp.Models.Where(p => p.Rol is "Administrador" or "Super Admin" or "Vendedor"))
            usuarios.Add(new UsuarioVM { Id = p.Id, Nombre = p.Nombre, Email = p.Email, Rol = p.Rol, DistribuidorId = p.DistribuidorId, Activo = p.Activo });
        cargando = false;
    }

    private async Task Crear()
    {
        msgCrear = null;
        if (string.IsNullOrWhiteSpace(nNombre) || string.IsNullOrWhiteSpace(nEmail) || string.IsNullOrWhiteSpace(nPass))
        { okCrear = false; msgCrear = "Completa nombre, email y contraseña."; return; }
        if (nPass.Length < 6) { okCrear = false; msgCrear = "La contraseña debe tener al menos 6 caracteres."; return; }

        creando = true;
        try
        {
            var err = await Auth.CrearUsuario(nNombre.Trim(), nEmail.Trim(), nPass, nRol);
            if (err is not null) { okCrear = false; msgCrear = err; return; }

            okCrear = true; msgCrear = $"Usuario {nEmail.Trim()} creado como {nRol}.";
            var creado = await Supa.From<Profile>().Where(p => p.Email == nEmail.Trim()).Single();
            if (creado is not null && usuarios.All(x => x.Id != creado.Id))
                usuarios.Insert(0, new UsuarioVM { Id = creado.Id, Nombre = creado.Nombre, Email = creado.Email, Rol = creado.Rol, DistribuidorId = creado.DistribuidorId, Activo = creado.Activo });
            nNombre = nEmail = nPass = ""; nRol = "Administrador";
        }
        catch (Exception ex) { okCrear = false; msgCrear = "No se pudo crear el usuario: " + ex.Message; }
        finally { creando = false; }
    }

    private async Task Guardar(UsuarioVM u)
    {
        msg = null;
        try
        {
            var p = new Profile { Id = u.Id, Nombre = u.Nombre, Email = u.Email, Rol = u.Rol, DistribuidorId = u.DistribuidorId, Activo = u.Activo };
            await Supa.From<Profile>().Update(p);
            ok = true; msg = $"Usuario {u.Email} actualizado.";
            if (u.Rol == "Distribuidor") usuarios.Remove(u); // ya no es administrativo
        }
        catch (Exception ex) { ok = false; msg = "No se pudo guardar: " + ex.Message; }
    }

    private sealed class UsuarioVM
    {
        public string Id { get; set; } = "";
        public string Nombre { get; set; } = "";
        public string? Email { get; set; }
        public string Rol { get; set; } = "Administrador";
        public long? DistribuidorId { get; set; }
        public bool Activo { get; set; } = true;
    }
}
